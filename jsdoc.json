{
  "source": {
    "include": [
      "src",
      "guides"
    ],
    "includePattern": ".+\\.js(doc|x)?$",
    "excludePattern": "(^|\\/|\\\\)_"
  },
  "opts": {
    "destination": "./docs",
    "recurse": true,
    "template": "./node_modules/docdash-extended"
  },
  "plugins": [
    "plugins/markdown",
    "node_modules/docdash-extended/categories"
  ],
  "templates": {
    "default": {
      "includeDate": false,
      "outputSourceFiles": false
    }
  },
  "tags": {
    "allowUnknownTags": true
  },
  "docdash": {
    "removeQuotes": "all"
  },
  "categoriesFile": "./categories.json"
}