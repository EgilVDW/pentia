{
  "source": {
    "include": ["src", "guides", "components"],
    "includePattern": ".+\\.(js|md)$"
  },
  "opts": {
    "destination": "./docs",
    "recurse": true,
    "template": "./node_modules/docdash-extended"
  },
  "plugins": ["plugins/markdown", "node_modules/docdash-extended/categories"],
  "templates": {
    "default": {
      "includeDate": false
    }
  },
  "categoriesFile": "./categories.json"
}
